<odoo>
    <record id="view_task_tree" model="ir.ui.view">
    <field name="name">task.tree</field>
    <field name="model">task</field>
    <field name="arch" type="xml">
      <tree string="Tasks List">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="assigned_to"/>
        <field name="priority"/>
        <field name="difficulty"/>
        <field name="status"/>
        <field name="is_active"/>
        <field name="created_at"/>
        <field name="deadline"/>
      </tree>
    </field>
  </record>

  <record id="view_task_kanban" model="ir.ui.view">
    <field name="name">task.kanban</field>
    <field name="model">task</field>
    <field name="arch" type="xml">
      <kanban class="o_kanban_example" type="form">
          <field name="status"/>
          <field name="priority"/>
          <field name="partner_id"/>
          <field name="deadline"/>
          <templates>
              <t t-name="kanban-box">
                  <div t-attf-class="oe_kanban_card oe_kanban_global_click">
                      <div class="oe_kanban_details">
                          <div class="oe_kanban_primary">
                              <strong><field name="name"/></strong>
                          </div>

                          <div class="oe_kanban_secondary">
                              <div>
                                  <span>Status: </span>
                                  <field name="status"/>
                              </div>
                              <div>
                                  <span>Priority: </span>
                                  <field name="priority"/>
                              </div>
                              <div>
                                  <span>Deadline: </span>
                                  <field name="deadline"/>
                              </div>
                              <div>
                                  <span>Difficulty: </span>
                                  <field name="difficulty"/>
                              </div>
                              <div>
                                  <span>Assigned to: </span>
                                  <field name="assigned_to"/>
                              </div>
                          </div>

                          <div t-if="record.partner_id.raw_value">
                              <field name="partner_id" widget="many2one_avatar"/>
                          </div>
                      </div>
                  </div>
              </t>
          </templates>
      </kanban>
    </field>
  </record>

  <record id="view_task_form" model="ir.ui.view">
    <field name="name">task.form</field>
    <field name="model">task</field>
    <field name="arch" type="xml">
      <form string="Task Form">
        <sheet>
          <group>
            <field name="name"/>
            <field name="partner_id"/>
            <field name="status"/>
            <field name="deadline"/>
            <field name="created_at"/>
            <field name="priority"/>
            <field name="is_active"/>
            <field name="difficulty"/>
            <field name="assigned_to"/>
          </group>
          <notebook>
            <page string="Images">
              <field name="image_ids">
                <tree editable="bottom">
                  <field name="image" widget="image" options="{'preview_image': 'image'}"/>
                  <field name="name"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
        <div class="oe_chatter">
          <field name="message_ids" widget="mail_thread"/>
        </div>
      </form>
    </field>
  </record>

  <record id="action_task" model="ir.actions.act_window">
    <field name="name">Tasks</field>
    <field name="res_model">task</field>
    <field name="view_mode">kanban,tree,form</field>
  </record>

  <menuitem id="menu_task_root" name="Task Manager"/>
  <menuitem id="menu_task_main"
            name="Tasks"
            parent="menu_task_root"
            action="action_task"/>
</odoo>