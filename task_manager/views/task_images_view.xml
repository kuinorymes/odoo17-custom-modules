<odoo>
    <record id="view_task_image_form" model="ir.ui.view">
  <field name="name">task.image.form</field>
  <field name="model">task.image</field>
  <field name="arch" type="xml">
    <form string="Task Image">
      <sheet>
        <group>
          <field name="task_id"/>
          <field name="image" widget="image"/>
          <field name="name"/>
        </group>
      </sheet>
    </form>
  </field>
</record>

<record id="view_task_image_tree" model="ir.ui.view">
  <field name="name">task.image.tree</field>
  <field name="model">task.image</field>
  <field name="arch" type="xml">
    <tree string="Task Images">
      <field name="task_id"/>
      <field name="name"/>
    </tree>
  </field>
</record>

</odoo>