<odoo>
    <record id="view_crm_lead_add_package_wizard_form" model="ir.ui.view">
        <field name="name">crm.lead.add.package.wizard.form</field>
        <field name="model">crm.lead.add.package.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Product Package">
                <group>
                    <field name="package_id"/>
                </group>
                <footer>
                    <button string="Add" type="object" name="add_package" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>