<odoo>
    <record id="action_crm_lead_add_package_wizard" model="ir.actions.act_window">
        <field name="name">Add Product Package</field>
        <field name="res_model">crm.lead.add.package.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_lead_id': active_id}</field>
    </record>

    <record id="view_crm_lead_form_inherit_products" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.products</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(action_crm_lead_add_package_wizard)d"
                        string="Add Product Package"
                        type="action"
                        class="btn-primary"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="Products">
                    <field name="product_line_ids">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="description"/>
                            <field name="product_quantity"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>