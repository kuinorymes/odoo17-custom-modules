<odoo>
  <record id="helpdesk_ticket_view_form_inherit_create_task" model="ir.ui.view">
    <field name="name">helpdesk.ticket.form.inherit.create.task</field>
    <field name="model">helpdesk.ticket</field>
    <field name="inherit_id" ref="helpdesk.helpdesk_ticket_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form/header" position="inside">
        <field name="user_has_task_access" invisible="1"/>
        <button name="create_task_wizard"
                string="Create Task"
                type="object"
                class="btn-primary"
                invisible="not user_has_task_access"
        />
      </xpath>
    </field>
  </record>
</odoo>