<odoo>
    <record id="view_crm_lead_product_package_tree" model="ir.ui.view">
        <field name="name">crm.lead.product.package.tree</field>
        <field name="model">crm.lead.product.package</field>
        <field name="arch" type="xml">
            <tree string="Product Packages">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_crm_lead_product_package_form" model="ir.ui.view">
        <field name="name">crm.lead.product.package.form</field>
        <field name="model">crm.lead.product.package</field>
        <field name="arch" type="xml">
            <form string="Product Package">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <notebook>
                        <page string="Products">
                            <field name="product_ids">
                                <tree editable="bottom">
                                    <field name="product_id"/>
                                    <field name="product_quantity"/>
                                    <field name="price_unit"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_crm_lead_product_package" model="ir.actions.act_window">
        <field name="name">Product Packages</field>
        <field name="res_model">crm.lead.product.package</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem id="menu_crm_lead_product_package_root"
              name="Product Packages"
              parent="crm.crm_menu_root"
              sequence="30"/>
    <menuitem id="menu_crm_lead_product_package"
              name="Packages"
              parent="menu_crm_lead_product_package_root"
              action="action_crm_lead_product_package"/>
</odoo>